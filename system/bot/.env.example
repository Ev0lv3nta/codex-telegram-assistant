TG_BOT_TOKEN=

# Optional access control. Comma-separated numeric IDs.
TG_ALLOWED_USER_IDS=
TG_ALLOWED_CHAT_IDS=

# Paths
ASSISTANT_ROOT=/root/personal-assistant
BOT_STATE_DB=/root/personal-assistant/system/tasks/bot_state.db

# Polling
TG_POLL_TIMEOUT_SEC=25
BOT_IDLE_SLEEP_SEC=1.0
AUTONOMY_ENABLED=false
AUTONOMY_HEARTBEAT_SEC=300
AUTONOMY_LOOP_POLL_SEC=60
AUTONOMY_DEFAULT_SLEEP_SEC=7200
AUTONOMY_BUSY_RETRY_SEC=120
AUTONOMY_SESSION_STEP_LIMIT=4
AUTONOMY_NOTIFY_ENABLED=false
AUTONOMY_NOTIFY_MIN_CHARS=1
AUTONOMY_NOTIFY_COOLDOWN_SEC=0
AUTONOMY_IDLE_ASK_ENABLED=false
AUTONOMY_IDLE_ASK_COOLDOWN_SEC=21600
AUTONOMY_IDLE_SLEEP_SEC=21600
BOT_SESSION_LEASE_SEC=1860

# Codex
CODEX_BIN=codex
CODEX_TIMEOUT_SEC=1800
CODEX_MODEL=gpt-5.2-codex
CODEX_EXTRA_ARGS=--dangerously-bypass-approvals-and-sandbox -c model_reasoning_effort=\"medium\"

# OpenRouter STT for voice messages
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_STT_MODEL=mistralai/voxtral-small-24b-2507
OPENROUTER_STT_TIMEOUT_SEC=90
OPENROUTER_STT_MAX_AUDIO_BYTES=26214400

# Bot output
BOT_MAX_RESULT_CHARS=3500
BOT_MAX_SEND_FILE_BYTES=52428800
BOT_LOG_LEVEL=INFO
